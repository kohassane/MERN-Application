generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  identifiant String   @unique
  email       String?  @unique
  password    String
  role        String
  firstName   String
  lastName    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]

  @@map("users")
}

model Event {
  id          String    @id @default(uuid())
  title       String
  date        DateTime
  location    String
  category    String
  description String
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  results Result[]

  @@map("events")
}

model Result {
  id        String     @id @default(uuid())
  eventId   String
  eventName String
  date      DateTime
  category  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  event Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teams TeamResult[]

  @@map("results")
}

model TeamResult {
  id       String @id @default(uuid())
  resultId String
  name     String
  score    Int
  position Int?

  result Result @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@map("team_results")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  imageUrl    String?
  category    String
  inStock     Boolean  @default(true)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]

  @@map("products")
}

model Partner {
  id          String   @id @default(uuid())
  name        String
  description String?
  logoUrl     String?
  websiteUrl  String?
  tier        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("partners")
}

model News {
  id        String   @id @default(uuid())
  title     String
  summary   String
  content   String
  date      DateTime
  imageUrl  String?
  author    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("news")
}

model Order {
  id        String   @id @default(uuid())
  userId    String
  status    String   @default("PENDING")
  total     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}
