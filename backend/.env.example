# Configuration du serveur
PORT=5000
NODE_ENV=development

# URL du frontend
FRONTEND_URL=http://localhost:5173

# Clé secrète JWT
JWT_SECRET=sport-ivoirien-secret-key-change-in-production

# Configuration de la base de données (si vous utilisez une vraie DB)
# DATABASE_URL=mongodb://localhost:27017/sport-ivoirien
# ou
# DATABASE_URL=postgresql://user:password@localhost:5432/sport_ivoirien

# Configuration email (pour les notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Configuration de stockage cloud (optionnel)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Configuration de paiement (pour l'e-commerce)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...